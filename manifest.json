{
  "manifest_version": 3,
  "name": "AnonTranslator II",
  "version": "1.3.8",
  "author": "raindrop213",
  "description": "Japanese reading and general text translation with Google and DeepSeek",
  "icons": {
    "16": "img/icon16.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["src/content.js"],
      "css": ["css/styles.css"],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://translate.google.com/m*",
    "https://translate.googleapis.com/*",
    "https://api.deepseek.com/*"
  ],
  "action": {"default_popup": "popup.html"},
  "background": {"service_worker": "src/background.js"}
}
